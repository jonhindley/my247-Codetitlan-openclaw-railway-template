#!/usr/bin/env python3

import argparse
import base64
import json
import mimetypes
import os
import urllib.request
from pathlib import Path

MEDIA_DIR = Path("/data/.openclaw/media/inbound")
IMAGE_EXTS = {".png", ".jpg", ".jpeg", ".webp"}

DEFAULT_PROMPT = (
    "Describe this image naturally and concisely. "
    "If there is any obvious humour, contrast, or notable context in the image, "
    "mention it lightly and appropriately."
)

def list_images():
    if not MEDIA_DIR.exists():
        return []
    files = [p for p in MEDIA_DIR.iterdir() if p.is_file() and p.suffix.lower() in IMAGE_EXTS]
    files.sort(key=lambda p: p.stat().st_mtime, reverse=True)
    return files

def latest_image():
    files = list_images()
    if not files:
        raise SystemExit("No inbound image files found.")
    return files[0]

def resolve_target(target):
    if not target or target == "latest":
        return latest_image()
    p = Path(target)
    if not p.exists() or not p.is_file():
        raise SystemExit(f"Image file not found: {target}")
    return p

def call_vision(image_path: Path, prompt: str):
    # Vision can use a dedicated my247 platform route, or fall back to the
    # customer's normal provider route when that model supports vision.
    base_url = (
        os.environ.get("MY247_VISION_PROVIDER_BASE_URL")
        or os.environ.get("MY247_PROVIDER_BASE_URL")
        or ""
    ).rstrip("/")

    api_key_env = os.environ.get("MY247_VISION_API_KEY_ENV", "OPENAI_API_KEY")
    api_key = (
        os.environ.get("MY247_VISION_API_KEY")
        or os.environ.get(api_key_env)
        or os.environ.get("OPENAI_API_KEY")
        or ""
    )

    model = (
        os.environ.get("MY247_VISION_MODEL_ID")
        or os.environ.get("MY247_MODEL_ID")
        or "gpt-4o-mini"
    )

    if not base_url:
        raise SystemExit("Missing MY247_PROVIDER_BASE_URL")
    if not api_key:
        raise SystemExit("Missing OPENAI_API_KEY")

    mime = mimetypes.guess_type(str(image_path))[0] or "image/jpeg"
    b64 = base64.b64encode(image_path.read_bytes()).decode("ascii")

    payload = {
        "model": model,
        "messages": [
            {
                "role": "user",
                "content": [
                    {"type": "text", "text": prompt},
                    {"type": "image_url", "image_url": {"url": f"data:{mime};base64,{b64}"}},
                ],
            }
        ],
        "temperature": 0.2,
    }

    req = urllib.request.Request(
        base_url + "/chat/completions",
        data=json.dumps(payload).encode("utf-8"),
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {api_key}",
        },
        method="POST",
    )

    with urllib.request.urlopen(req, timeout=120) as r:
        body = json.loads(r.read().decode("utf-8"))

    try:
        return body["choices"][0]["message"]["content"].strip()
    except Exception:
        return json.dumps(body, indent=2)

def cmd_latest(_args):
    print(latest_image())

def cmd_list(args):
    files = list_images()
    if not files:
        print("No inbound image files found.")
        return
    for f in files[: args.max]:
        print(f)

def cmd_describe(args):
    image_path = resolve_target(args.target)
    result = call_vision(image_path, args.prompt or DEFAULT_PROMPT)
    print(result)

def main():
    parser = argparse.ArgumentParser(description="my24-7assistant media helper")
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("latest")
    p.set_defaults(func=cmd_latest)

    p = sub.add_parser("list")
    p.add_argument("--max", type=int, default=10)
    p.set_defaults(func=cmd_list)

    p = sub.add_parser("describe")
    p.add_argument("target", nargs="?", default="latest")
    p.add_argument("--prompt")
    p.set_defaults(func=cmd_describe)

    args = parser.parse_args()
    args.func(args)

if __name__ == "__main__":
    main()
